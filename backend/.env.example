# Local dev environment — copy to .env and fill in real values
# Lambda gets these injected at deploy time from SSM/Secrets Manager

# DB connection string (local dev only; Lambda uses DB_DSN built from SSM at deploy time)
# Must be keyword/value format, not a postgresql:// URL — _resolve_dsn() in
# app/db/postgres_client.py appends " connect_timeout=..." to this string, which
# only parses correctly in keyword/value form.
DB_DSN=host=localhost port=5432 dbname=crypto_assist user=user password=password

# Cognito pool (read from SSM /crypto-assist/dev/CognitoUserPoolId in Lambda)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1

# CoinGecko API key (SecureString in SSM /crypto-assist/{stage}/CoingeckoApiKey)
COINGECKO_API_KEY=

# CORS origin for local frontend
FRONTEND_ORIGIN=http://localhost:5173
